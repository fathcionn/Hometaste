{
  "cli": { "version": ">= 10.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false, "enterpriseProvisioning": "adhoc" }
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "app-bundle", "gradleCommand": ":app:bundleRelease" },
      "ios": { "image": "macos-sonoma-14.6-xcode-16.2", "simulator": false }
    }
  },
  "submit": {
    "production": {
      "android": { "serviceAccountKeyPath": "./google-play-key.json", "track": "internal" },
      "ios": { "appleId": "your@email.com", "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID", "appleTeamId": "YOUR_TEAM_ID" }
    }
  }
}
