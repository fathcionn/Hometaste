NODE_ENV="development"
PORT="4173"
LOG_LEVEL="info"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hometaste?schema=public"

REDIS_URL="redis://localhost:6379"

JWT_ACCESS_SECRET="replace-me-with-64-char-hex"
JWT_REFRESH_SECRET="replace-me-with-64-char-hex"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_UPLOAD_PRESET="hometaste_uploads"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

IYZICO_API_KEY="your_sandbox_api_key"
IYZICO_SECRET_KEY="your_sandbox_secret"
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"

EXPO_ACCESS_TOKEN="your_expo_token"

CLIENT_ORIGIN="http://localhost:3000"
