{
  "name": "@hometaste/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./translations/*": "./src/translations/*.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@hometaste/config": "workspace:*",
    "typescript": "5.9.2"
  }
}
